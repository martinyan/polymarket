NODE_ENV=development
PORT=8080

# Comma-separated trader addresses to follow
USER_ADDRESSES=0x0000000000000000000000000000000000000000

# Preview mode logs intended trades without placing orders
PREVIEW_MODE=true

# Trading wallet
PRIVATE_KEY=
FUNDER_ADDRESS=

# Official Polymarket endpoints
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com
CHAIN_ID=137

# Copy behavior
POLL_INTERVAL_MS=5000
MAX_ACTIVITY_PAGES=2
MAX_ORDER_USD=5
MIN_ORDER_USD=1
COPY_RATIO=0.02
MAX_SLIPPAGE=0.03
BUY_ONLY=true

# Optional market filtering
ALLOWED_TAGS=
ALLOWED_EVENT_KEYWORDS=temperature,climate,weather
BLOCKED_SLUGS=

# State
STATE_PATH=./data/state.json
