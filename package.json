{
  "name": "clean-polymarket-copy-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Auditable Polymarket copy trading bot built from scratch",
  "type": "commonjs",
  "scripts": {
    "backtest": "tsx src/backtest.ts",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsx src/check.ts",
    "preview:once": "tsx src/preview.ts",
    "test": "node --import tsx --test src/activity.test.ts src/bot.test.ts src/strategy.test.ts src/weather/ev.test.ts src/weather/aviation.test.ts src/weather/postprocess.test.ts",
    "weather": "tsx src/weather/analyze.ts",
    "weather:train": "node --import tsx src/weather/train_postprocess.ts",
    "weather:viz": "tsx src/weather/visualize.ts",
    "weather:bet": "tsx src/weather/bet.ts",
    "weather:fwdtest": "tsx src/weather/forwardtest.ts",
    "weather:retro": "tsx src/weather/retro_backtest.ts",
    "weather:snapshot": "tsx src/weather/snapshot.ts",
    "weather:snapshot:analyze": "tsx src/weather/snapshot_analyze.ts"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.8.1",
    "dotenv": "^16.6.1",
    "ethers": "5.8.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
